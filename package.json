		"test:run": "vitest --run",
		"coverage": "vitest --coverage"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^4.0.0",
		"@testing-library/user-event": "^14.5.0",
		"@vitest/ui": "^1.0.0",
		"jsdom": "^23.0.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^1.0.0"
	}
}
