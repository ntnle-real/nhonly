# Environment Configuration
# Copy to .env.local (dev) or .env.production (live)
# NEVER commit actual secrets to .env files

# Application Environment
NODE_ENV=development
PUBLIC_ENVIRONMENT=development

# API & Data Layer
# These should point to DIFFERENT databases for dev vs. production
PUBLIC_API_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://localhost:5432/nhonly_dev

# Authentication (if implemented later)
# AUTH_SECRET=your-secret-here

# Feature Flags (control which features are enabled in each environment)
PUBLIC_ENABLE_RECORDING=true
PUBLIC_ENABLE_DIORAMA=true
