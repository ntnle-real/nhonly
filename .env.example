# Environment Configuration
# Copy to .env.local (dev) or .env.production (live server only)
# NEVER commit actual secrets to .env files

# Application Environment
NODE_ENV=development
PUBLIC_ENVIRONMENT=development

# Supabase Configuration (from supabase.com dashboard)
# PUBLIC variables: Safe to expose in browser (anon key has limited permissions)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Service Role Key: ONLY on production server, NEVER exposed to client
# This is a secret key — store in .env.production ONLY
# Dev machine: Can be optional (uses anon key for testing)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Feature Flags (control which features are enabled in each environment)
PUBLIC_ENABLE_RECORDING=true
PUBLIC_ENABLE_DIORAMA=true
